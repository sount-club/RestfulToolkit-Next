<idea-plugin url="https://github.com/sount-club/RestfulToolkit-Next" allow-bundled-update="true">
	<!-- Unique identifier of the plugin. It should be FQN, cannot be changed between the plugin versions. -->
	<id>com.sount</id>

	<!-- Public plugin name should be written in Title Case.
		 Guidelines: https://plugins.jetbrains.com/docs/marketplace/best-practices-for-listing.html#plugin-name -->
	<name>RestfulToolkit Next</name>

	<!-- A displayed Vendor name or Organization ID displayed on the Plugins Page. -->
	<vendor url="https://github.com/sount-club/RestfulToolkit-Next">Sount-Club</vendor>

	<!-- Description of the plugin displayed on the Plugin Page and IDE Plugin Manager.
		 Guidelines: https://plugins.jetbrains.com/docs/marketplace/best-practices-for-listing.html#plugin-description -->
	<description><![CDATA[
  <h3>RestfulToolkit Next</h3>
  <p>
    A maintained re-release based on the original
    <a href="https://github.com/mrmanzhaow/RestfulToolkit">RestfulToolkit</a>,
    adapted for newer IntelliJ IDEA / JetBrains Platform versions.
  </p>
  <ul>
    <li>Jump to REST endpoint declarations by URL</li>
    <li>Browse REST services in the <em>RestServices</em> tool window</li>
    <li>Generate and copy full URL, relative URL, query params, and request body JSON</li>
    <li>Convert Java / Kotlin classes to JSON or bulk values</li>
    <li>Supports Spring MVC / Spring Boot, JAX-RS, Java, and Kotlin</li>
  </ul>
  <p>
    Quick navigation shortcut:
    <code>Ctrl + \</code> / <code>Ctrl + Alt + N</code> on Windows and Linux,
    <code>Command + \</code> on macOS.
  </p>

  <hr />

  <h3>二次开发说明</h3>
  <p>
    本插件基于原始项目
    <a href="https://github.com/mrmanzhaow/RestfulToolkit">RestfulToolkit</a>
    进行二次开发和重新发布，主要用于适配较新的 IntelliJ IDEA / JetBrains Platform 版本。
  </p>
  <ul>
    <li>支持根据 URL 快速跳转到接口定义</li>
    <li>支持通过 <em>RestServices</em> 工具窗口浏览接口结构</li>
    <li>支持在接口方法上生成并复制 URL、请求参数和 RequestBody</li>
    <li>支持在 Java / Kotlin 类上执行 JSON 转换</li>
  </ul>
  <p>
    常用快捷键：
    Windows / Linux 使用 <code>Ctrl + \</code> 或 <code>Ctrl + Alt + N</code>，
    macOS 使用 <code>Command + \</code>。
  </p>
    ]]></description>
	<change-notes><![CDATA[
        <p><strong>RestfulToolkit Next 1.0.1</strong></p>
        <ul>
          <li>Grouped editor context-menu actions under the RestfulToolkit Next submenu</li>
          <li>Fixed method and class right-click actions so they resolve from the current caret/context element</li>
          <li>Improved RestServices request panel with searchable endpoints, editable headers, body modes, and response metadata</li>
        </ul>
    ]]>
	</change-notes>



	<!-- Product and plugin compatibility requirements.
		 Read more: https://plugins.jetbrains.com/docs/intellij/plugin-compatibility.html -->
	<depends>com.intellij.modules.compose</depends>
	<depends>com.intellij.java</depends>
	<depends>org.jetbrains.kotlin</depends>

	<idea-version since-build="261"/>

	<!-- Extensions defined by the plugin.
		 Read more: https://plugins.jetbrains.com/docs/intellij/plugin-extension-points.html -->
	<extensions defaultExtensionNs="com.intellij">
		<projectService serviceImplementation="com.sount.restful.navigation.action.GotoRequestMappingConfiguration"/>
		<projectService serviceImplementation="com.sount.restful.navigator.RestServiceProjectsManager"/>
		<projectService serviceImplementation="com.sount.restful.navigator.RestServicesNavigator"/>
		<projectService serviceImplementation="com.sount.restful.navigator.RestServiceDetail"/>
		<toolWindow id="RestServices"
					anchor="right"
					icon="/icons/restService.svg"
					canCloseContents="false"
					factoryClass="com.sount.restful.navigator.RestServicesToolWindowFactory"/>
	</extensions>

	<extensions defaultExtensionNs="org.jetbrains.kotlin">
		<supportsKotlinPluginMode supportsK2="true"/>
	</extensions>

	<!-- Actions defined by the plugin -->
	<actions>
		<!--主弹出菜单动作 - Ctrl+\ 或 Command+\ 触发 -->
		<action id="PopupChoiceAction" class="com.sount.restful.popup.action.PopupChoiceAction"
				text="RestfulToolkit Next" icon="/icons/restService.svg">
			<add-to-group group-id="MainMenu" anchor="last"/>
		</action>

		<!--在controller method 中添加 RestfulToolkit 弹出操作，generate rest url、generate rest url with Possibly params （添加可能的参数，解析实体，@RequestBody）、gen json、
        gen key value for postman(postman 参数bulk edit)、 gen key value for apiview submit -->
		<!--rest 方法中添加-->
		<group id="RestfulToolkitGroup" text="RestfulToolkit Next"
			   description="RestfulToolkit Next actions for REST methods"
			   popup="true"
			   icon="/icons/restService.svg">
			<add-to-group group-id="EditorPopupMenu" anchor="first"/>
			<action class="com.sount.restful.method.action.GenerateFullUrlAction" id="GenerateFullRestUrl"
					text="Generate &amp;&amp; Copy Full URL"/>
			<action class="com.sount.restful.method.action.GenerateUrlAction" id="GenerateRestUrl"
					text="Generate &amp;&amp; Copy Relation URL"/>
			<action class="com.sount.restful.method.action.GenerateQueryParamJsonAction" id="GenerateRequestBodyJson"
					text="Generate &amp;&amp; Copy RequestBody (JSON)"/>
			<action class="com.sount.restful.method.action.GenerateQueryParamAction" id="BuildQueryParam"
					text="Generate &amp;&amp; Copy Query Param (Key Value)"/>
			<separator/>
			<action id="ConvertClassToJSONAction" class="com.sount.restful.action.ConvertClassToJSONAction"
					text="Convert to JSON" description="Convert to JSON"/>
			<action id="ConvertClassToJSONCompressedAction"
					class="com.sount.restful.action.ConvertClassToJSONCompressedAction" text="Convert to JSON (Compressed)"
					description="Convert to JSON (Compressed)"/>
			<action id="ConvertClassToBulkValueAction" class="com.sount.restful.action.ConvertClassToBulkValueAction"
					text="Convert to Bulk Value" description="Convert to Bulk Value"/>
		</group>

		<!-- url 导航 -->
		<action id="Toolkit.GotoService" class="com.sount.restful.navigation.action.GotoRequestMappingAction"
				text="_Service" description="Go to Service"
				icon="/icons/restService.svg">
			<add-to-group group-id="GoToTargetEx" anchor="first"/>
			<keyboard-shortcut keymap="Mac OS X" first-keystroke="meta BACK_SLASH"/>
			<keyboard-shortcut keymap="Mac OS X 10.5+" first-keystroke="meta BACK_SLASH"/>
			<keyboard-shortcut keymap="$default" first-keystroke="ctrl BACK_SLASH"/>
			<keyboard-shortcut keymap="$default" first-keystroke="ctrl alt N"/>
		</action>

		<!--刷新-->
		<action id="Toolkit.RefreshServices" class="com.sount.restful.navigator.RefreshProjectAction"
				text="Refresh Services in Project"
				icon="AllIcons.Actions.Refresh">
		</action>

		<group id="Toolkit.NavigatorActionsToolbar">
			<reference id="Toolkit.RefreshServices"/>
			<separator/>
			<reference id="Toolkit.GotoService"/>
			<separator/>
		</group>

		<group id="Toolkit.NavigatorServiceMenu">
			<action id="Menu.CopyFullUrlAction" class="com.sount.restful.navigator.CopyFullUrlAction"
					text="Copy Full Url"
					icon="AllIcons.Actions.Copy">
			</action>
			<action id="Menu.EditSourceAction" class="com.sount.restful.navigator.EditSourceAction"
					text="Jump to Source"
					icon="AllIcons.Actions.EditSource">
			</action>
			<separator/>
		</group>
	</actions>

	<projectListeners>
		<listener class="com.sount.restful.navigator.MyToolwindowListener" topic="com.intellij.openapi.wm.ex.ToolWindowManagerListener" />
	</projectListeners>
</idea-plugin>
